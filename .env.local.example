# Where downloaded EPUBs are stored. Will be created if it doesn't exist.
BOOKSHELF_DIR=~/BookShelf

# Anna's Archive donor account ID (the value of the aa_account_id2 cookie).
# Required for automated server-side downloads via the Fast Partner Servers.
# Leave blank for now; without it, downloads open in your browser and the app
# auto-imports the resulting EPUB from ~/Downloads.
AA_DONOR_KEY=

# Override the Anna's Archive mirror if .gl is unreachable.
AA_BASE_URL=https://annas-archive.gl

# Prefix displayed before "Library" in the page header and tab title
# (e.g. "Richmond" -> "Richmond Library", "Marisa's" -> "Marisa's Library").
LIBRARY_NAME=Richmond
